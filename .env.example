# ===== 复制为 .env 并按需修改 =====  cp .env.example .env
#
# 本文件只放「部署 / 面板」相关配置。
# 服务端启动参数与服务器设置(名称/密码/端口/多线程等) 全部在:  game/server.env
#   ->  cp game/server.env.example game/server.env

# ---- 通用 ----
TZ=Asia/Shanghai

# ---- Web 管理面板 ----
# 面板访问端口 (浏览器 http://<服务器IP>:8000)
PANEL_PORT=8000
PANEL_USERNAME=admin
PANEL_PASSWORD=change_this_panel_password
# JWT 签名密钥, 请改成随机长字符串:  openssl rand -hex 32
JWT_SECRET=please_change_me_to_a_random_64_char_hex_string

# ---- Docker 镜像加速 (可选, 供 prepare-images.sh 使用) ----
# 拉取 docker 镜像时的前缀镜像站, 国内推荐填, 留空则直连 Docker Hub
# 例:  docker.m.daocloud.io   或   dockerproxy.net   等可用镜像站
REGISTRY_MIRROR=

# ---- 构建面板时的依赖源 (可选, 已默认国内源, 一般无需改) ----
# pip 源, 默认清华; 可换阿里 https://mirrors.aliyun.com/pypi/simple
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# npm 源, 默认淘宝镜像
NPM_REGISTRY=https://registry.npmmirror.com

# ---- 代理 (可选, 若服务器需科学上网拉取 steam/更新) ----
# 游戏容器运行时代理 (指向宿主机代理; 容器内需用宿主机地址)
SERVER_HTTP_PROXY=
# 构建面板镜像时的代理 (pip/npm 拉取依赖). 本机构建可填 http://host.docker.internal:7890
BUILD_HTTP_PROXY=

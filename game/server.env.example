# ============================================================================
# 幻兽帕鲁 服务端配置 (单一来源)  ——  复制为 server.env:  cp game/server.env.example game/server.env
#
# 本文件集中管理「服务端启动参数」与「核心服务器设置」, 由 game/entrypoint.sh 读取:
#   - 前半部分 -> 拼成 PalServer.sh 的命令行启动参数 (arguments)
#   - 后半部分 -> 写入 PalWorldSettings.ini 的 OptionSettings (configuration)
# 参考:
#   https://docs.palworldgame.com/settings-and-operation/arguments
#   https://docs.palworldgame.com/settings-and-operation/configuration
#
# 注意: env_file 格式为 KEY=VALUE, 值两边不要加引号 (会被当成字面量)。
# ============================================================================

# ---------- 运维 (容器行为) ----------
TZ=Asia/Shanghai
# 每次启动是否用 steamcmd 校验更新服务端 (false 可加快重启)
UPDATE_ON_BOOT=true

# ---------- 启动参数 (arguments -> PalServer.sh) ----------
# 监听端口 (改这里需同步改 docker-compose.yml 的端口映射)
PORT=8211
# 最大在线人数
PLAYERS=32
# 性能多线程参数; 官方文档说明 v1.0+ 不设置可能反而更好, 故默认 false。
# 需要时改 true, 会追加: -useperfthreads -NoAsyncLoadingThread -UseMultithreadForDS
USE_PERF_THREADS=false
# 工作线程数 (留空不设置); 需配合上面的多线程参数, 见官方 Performances 说明
NUMBER_OF_WORKER_THREADS=
# 作为社区服发布 (追加 -publiclobby)
PUBLIC_LOBBY=false
# 手动指定公网 IP / 端口 (社区服才生效, 留空自动探测)
PUBLIC_IP=
PUBLIC_PORT=
# 日志格式:  text 或 json (留空用默认)
LOG_FORMAT=
# 其它自定义启动参数, 原样追加到命令行末尾 (高级用法, 留空即可)
EXTRA_ARGS=

# ---------- 核心服务器设置 (configuration -> PalWorldSettings.ini) ----------
SERVER_NAME=My Palworld Server
SERVER_DESCRIPTION=Powered by palworld-panel
# 进服密码 (留空为公开服)
SERVER_PASSWORD=
# 管理员密码: 用于 REST API 认证 (面板据此管理服务器), 必填!
# 建议只用字母数字, 避免逗号/引号 (帕鲁配置以逗号分隔, 含逗号会导致解析异常)
ADMIN_PASSWORD=change_this_admin_password

# ---------- 面板依赖项 (一般无需修改) ----------
# 面板通过官方 REST API 管理服务器, 端口保持与 compose 映射一致
# (RCON 已废弃, 本项目全程使用 REST API)
REST_API_PORT=8212

# 说明: 经验值倍率、掉落率、死亡惩罚等大量「玩法平衡」设置,
#       启动后直接在 Web 面板「服务器设置」里在线编辑即可, 无需写在这里。
